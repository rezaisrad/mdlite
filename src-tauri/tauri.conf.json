{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDLite",
  "version": "0.1.0",
  "identifier": "com.rezarad.mdlite",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "MDLite",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlEREE0QzQyQkE3MTAwMUIKUldRYkFIRzZRa3phbmVVVk03eHVFWGF2NWlDemlTQWI0VWZLVHlyRjZGc004L0owUFdvOEJzOEcK",
      "endpoints": []
    }
  }
}
